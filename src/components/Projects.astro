---
import { siteConfig } from "../config";
const hasProjects = siteConfig.projects && siteConfig.projects.length > 0;
---

{
  hasProjects && (
    <section id="projects" class="p-8 sm:p-12 md:p-16 lg:p-24" style="background-color: #34333a;">
      <div>
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-16 items-start">
          <div class="lg:col-span-4">
            <h2 class="text-3xl sm:text-4xl md:text-5xl xl:text-7xl font-bold text-gray-100">
              Projects
            </h2>
            <div
              class="w-[85px] h-[5px] mt-2 rounded-full"
              style={`background-color: ${siteConfig.accentColor}`}
            />
          </div>

          <div class="lg:col-span-8">
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
              {siteConfig.projects.map((project, index) => {
                const Component = project.link ? "a" : "div";
                const linkProps = project.link
                  ? {
                      href: project.link,
                      target: "_blank",
                      rel: "noopener noreferrer",
                    }
                  : {};

                return (
                  <div class="group relative">
                    <Component
                      {...linkProps}
                      class={`flex flex-col h-full relative p-4 sm:p-5 rounded-xl border border-gray-500 transition-all duration-300 ${
                        project.link
                          ? "hover:border-gray-300 hover:shadow-xl hover:shadow-black/30 hover:-translate-y-1"
                          : ""
                      }`}
                      style={`background-color: #44434D;`}
                      onmouseenter={`
                        this.querySelector('.arrow-btn')?.style.setProperty('background-color', 'color-mix(in srgb, ${siteConfig.accentColor} 75%, transparent)');
                        this.querySelectorAll('.skill-tag').forEach(el => el.style.setProperty('background-color', 'color-mix(in srgb, ${siteConfig.accentColor} 75%, transparent)'));
                      `}
                      onmouseleave={`
                        this.querySelector('.arrow-btn')?.style.setProperty('background-color', 'color-mix(in srgb, ${siteConfig.accentColor} 40%, transparent)');
                        this.querySelectorAll('.skill-tag').forEach(el => el.style.setProperty('background-color', 'color-mix(in srgb, ${siteConfig.accentColor} 30%, transparent)'));
                      `}
                    >
                      {project.link && (
                        <div
                          class="arrow-btn absolute top-4 right-4 w-8 h-8 flex items-center justify-center rounded-xl text-white transition-all duration-300"
                          style={`background-color: color-mix(in srgb, ${siteConfig.accentColor} 40%, transparent);`}
                        >
                          <svg
                            class="w-3.5 h-3.5 transition-transform duration-300 group-hover:translate-x-0.5 group-hover:-translate-y-0.5"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                          >
                            <path
                              stroke-linecap="round"
                              stroke-linejoin="round"
                              stroke-width="2"
                              d="M7 17L17 7M17 7H7M17 7V17"
                            />
                          </svg>
                        </div>
                      )}

                      <div class="flex flex-col gap-3 flex-1">
                        <div>
                          <span
                            class="text-xs font-mono"
                            style={{ color: siteConfig.accentColor }}
                          >
                            0{index + 1}
                          </span>
                          <h3 class="text-base sm:text-lg font-bold text-gray-200 mt-0.5 pr-8">
                            {project.name}
                          </h3>
                        </div>

                        <p class="text-sm text-gray-300 leading-relaxed flex-1">
                          {project.description}
                        </p>

                        {project.skills && project.skills.length > 0 && (
                          <div class="flex flex-wrap gap-1.5 pt-1">
                            {project.skills.map((skill) => (
                              <span
                                class="skill-tag px-2 py-1 rounded-md text-xs font-medium transition-all duration-300 text-gray-300"
                                style={`background-color: color-mix(in srgb, ${siteConfig.accentColor} 30%, transparent);`}
                              >
                                {skill}
                              </span>
                            ))}
                          </div>
                        )}
                      </div>
                    </Component>
                  </div>
                );
              })}
            </div>
          </div>
        </div>
      </div>
    </section>
  )
}